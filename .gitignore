# --- Rust/Cargo Specific ---
# The target directory contains all compiled binaries, intermediate objects, and debug symbols.
/target/

# --- Local Environment & Secrets ---
# Private environment variables, tokens, or API keys should never be committed.
.env
*.env
.env.local

# --- IDEs and Text Editors ---
# JetBrains / IntelliJ / RustRover
.idea/
*.iml

# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Vim / Emacs swap files
*~
*.swp

# OS generated files
.DS_Store
Thumbs.db
